{
  "name": "beacon",
  "version": "4.0.0",
  "private": true,
  "description": "GetOut Activation Command Center — internal analytics dashboard",
  "type": "module",
  "bin": {
    "beacon": "./bin/beacon.js"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "beacon": "concurrently --kill-others -n server,client -c blue,green \"node server/index.js\" \"vite\"",
    "dev": "npm run beacon",
    "build": "vite build",
    "server": "node server/index.js",
    "client": "vite",
    "electron:dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dist:publish": "npm run build && electron-builder --publish always"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "lucide-react": "^0.469.0",
    "multer": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0",
    "sucrase": "^3.35.1",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "vite": "^6.0.0"
  }
}
